--- recovered/Global.gd
+++ recovered/Global.gd
@@ -16,6 +16,13 @@
 
 const G = 100000.0
 
+## Mod settings
+const DELAY_SPEED: float = 0.25        ## seconds between auto-play actions; 0.0 = instant
+const AUTO_BUY_UPGRADES: bool = false  ## automatically purchase upgrades on the upgrade screen
+const AUTO_ADVANCE_TIER: bool = false  ## automatically advance after the between-tier summary
+const AUTO_ADVANCE_END: bool = false   ## automatically advance after the end-of-run summary
+const GAME_SPEED_CONTROL: bool = false ## Q/R keys scale game speed 1x-10x during the playing phase
+
 var load_saved_run = true
 
 
@@ -26,6 +33,8 @@
 var game_state: Util.GAME_STATES:
     set(new_value):
         game_state = new_value
+        if GAME_SPEED_CONTROL and game_state != Util.GAME_STATES.PLAYING:
+            Engine.time_scale = 1.0
         SignalBus.game_state_changed.emit()
 
         update_mouse()
@@ -50,6 +59,18 @@
     update_input_stuff(input_type)
 
 
+func _unhandled_input(event: InputEvent) -> void:
+    if not GAME_SPEED_CONTROL:
+        return
+    if game_state != Util.GAME_STATES.PLAYING:
+        return
+    if event is InputEventKey and event.pressed and not event.echo:
+        if event.keycode == KEY_R:
+            Engine.time_scale = minf(Engine.time_scale + 1.0, 10.0)
+        elif event.keycode == KEY_Q:
+            Engine.time_scale = maxf(Engine.time_scale - 1.0, 1.0)
+
+
 func new_game():
     rng = RandomNumberGenerator.new()
     rng.randomize()
