+
+func _score_object(obj: SpaceObject) -> float:
+    var score = float(obj.base_value)
+
+    # Tier 1: Comets and UFOs — highest priority, time-limited, die on contact
+    if obj is Comet or obj is UFO:
+        score += 2000.0
+        score -= obj.global_position.distance_to(global_position) * 0.05
+        return score
+
+    # Tier 2/3: Secondary scoring (applies within each pool)
+    # Prefer nearly-dead objects — faster kill, faster reward
+    if obj.health_component and obj.health_component.max_health > 0:
+        var health_pct = float(obj.health_component.current_health) / float(obj.health_component.max_health)
+        score += (1.0 - health_pct) * 50.0
+
+    # Proximity bias: break ties in favour of nearby objects
+    score -= obj.global_position.distance_to(global_position) * 0.05
+
+    return score
+
+func _find_best_target() -> SpaceObject:
+    if not Global.main or not Global.main.object_manager:
+        return null
+
+    var om = Global.main.object_manager
+    var best_lifetime_score = -INF
+    var best_lifetime_obj: SpaceObject = null
+    var best_modified_score = -INF
+    var best_modified_obj: SpaceObject = null
+    var best_score = -INF
+    var best_obj: SpaceObject = null
+
+    # Lifetime and modified objects are always scanned globally:
+    # - Comets/UFOs are not registered in the spatial grid so get_objects_near
+    #   will never return them, even with filter_misc_object = false.
+    # - Modified objects may spawn anywhere on the map outside the local radius.
+    for obj in om.get_all_active_objects(true):
+        if obj.is_dying:
+            continue
+        if not obj.is_misc_type and (not obj.is_active or not obj.can_be_damaged):
+            continue
+        var score = _score_object(obj)
+        if obj is Comet or obj is UFO:
+            if score > best_lifetime_score:
+                best_lifetime_score = score
+                best_lifetime_obj = obj
+        elif obj.special_type != null:
+            if score > best_modified_score:
+                best_modified_score = score
+                best_modified_obj = obj
+
+    # Unmodified objects use the local spatial scan so proximity bias applies.
+    var search_radius = 600.0 * Util.get_zoom_factor()
+    var local_objects = om.get_objects_near(global_position, search_radius, true, true)
+    if local_objects.is_empty():
+        local_objects = om.get_all_active_objects(false)
+    for obj in local_objects:
+        if obj.is_dying or not obj.is_active or not obj.can_be_damaged:
+            continue
+        var score = _score_object(obj)
+        if score > best_score:
+            best_score = score
+            best_obj = obj
+
+    if best_lifetime_obj != null:
+        return best_lifetime_obj
+    if best_modified_obj != null:
+        return best_modified_obj
+    return best_obj
 
